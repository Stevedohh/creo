{
  "name": "@creo/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx run-many --target=serve --projects=api,web --parallel",
    "start:api": "nx serve api",
    "start:web": "nx serve web",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f",
    "db:up": "docker compose up -d postgres",
    "db:migrate": "cd libs/prisma && npx prisma migrate dev --schema=schema/schema.prisma",
    "db:migrate:deploy": "cd libs/prisma && npx prisma migrate deploy --schema=schema/schema.prisma",
    "db:generate": "cd libs/prisma && npx prisma generate --schema=schema/schema.prisma",
    "db:studio": "cd libs/prisma && npx prisma studio --schema=schema/schema.prisma",
    "db:reset": "cd libs/prisma && npx prisma migrate reset --schema=schema/schema.prisma",
    "storybook": "nx storybook ui"
  },
  "private": true,
