# PostgreSQL
POSTGRES_DB=creo
POSTGRES_USER=creo
POSTGRES_PASSWORD=creo
POSTGRES_PORT=5433

# Database URL (used by Prisma and API)
DATABASE_URL=postgresql://creo:creo@localhost:5433/creo?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-to-random-string
JWT_REFRESH_SECRET=change-me-to-random-string

# OpenRouter (AI)
OPENROUTER_API_KEY=change-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# MiniMax (TTS + voice cloning)
MINIMAX_API_KEY=change-me
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Redis (BullMQ queue)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Object storage (S3-compatible)
# Local dev defaults target MinIO via docker-compose.
# Prod: see PROD.md for Cloudflare R2 setup instructions.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
# Public endpoint used for presigned URLs returned to the browser.
# Must be reachable from the user's machine. In prod set it equal to S3_ENDPOINT.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=creo-voiceovers
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGNED_TTL=604800
