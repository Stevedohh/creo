# PostgreSQL
POSTGRES_DB=creo
POSTGRES_USER=creo
POSTGRES_PASSWORD=creo
POSTGRES_PORT=5433

# Database URL (used by Prisma and API)
DATABASE_URL=postgresql://creo:creo@localhost:5433/creo?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-to-random-string
JWT_REFRESH_SECRET=change-me-to-random-string

# OpenRouter (AI)
OPENROUTER_API_KEY=change-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
