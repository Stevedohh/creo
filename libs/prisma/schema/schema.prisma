generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  language     String   @default("en")
  role         String   @default("user")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  voices        Voice[]
  scripts       Script[]
  projects      Project[]

  @@map("users")
}

model Project {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  title        String
  description  String?
  timeline     Json     @default("{\"version\":1,\"tracks\":[]}")
  thumbnailKey String?  @map("thumbnail_key")
  status       String   @default("draft")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("projects")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Voice {
  id             String   @id @default(uuid())
  minimaxVoiceId String   @map("minimax_voice_id")
  name           String
  sourceUrl      String?  @map("source_url")
  status         String   @default("active")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceovers Voiceover[]

  @@unique([userId, minimaxVoiceId])
  @@index([userId])
  @@map("voices")
}

model Script {
  id        String   @id @default(uuid())
  title     String
  content   String   @default("") @db.Text
  country   String?
  wordCount Int      @default(0) @map("word_count")
  rating    Int      @default(0)
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceovers Voiceover[]

  @@index([userId])
  @@map("scripts")
}

model Voiceover {
  id                String    @id @default(uuid())
  scriptId          String    @map("script_id")
  voiceId           String    @map("voice_id")
  minimaxTaskId     String?   @map("minimax_task_id")
  minimaxFileId     String?   @map("minimax_file_id")
  audioUrl          String?   @map("audio_url")
  audioExpiresAt    DateTime? @map("audio_expires_at")
  storageKey        String?   @map("storage_key")
  storageBytes      Int?      @map("storage_bytes")
  storageUploadedAt DateTime? @map("storage_uploaded_at")
  subtitlesKey      String?   @map("subtitles_key")
  status            String    @default("pending")
  characterCount    Int       @map("character_count")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  voice  Voice  @relation(fields: [voiceId], references: [id], onDelete: Cascade)

  @@index([scriptId])
  @@map("voiceovers")
}
