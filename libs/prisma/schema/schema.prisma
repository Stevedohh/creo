generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  language     String   @default("en")
  role         String   @default("user")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  voices        Voice[]
  scripts       Script[]
  projects      Project[]
  mediaAssets   MediaAsset[]
  ingestJobs    IngestJob[]
  renderJobs    RenderJob[]

  @@map("users")
}

model Project {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  title        String
  description  String?
  timeline     Json     @default("{\"version\":1,\"tracks\":[]}")
  thumbnailKey String?  @map("thumbnail_key")
  status       String   @default("draft")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets     ProjectAsset[]
  renderJobs RenderJob[]

  @@index([userId])
  @@map("projects")
}

model RenderJob {
  id               String    @id @default(uuid())
  // Nullable for ad-hoc document renders (e.g. `/remotion` sandbox)
  // that don't belong to a saved Project.
  projectId        String?   @map("project_id")
  userId           String    @map("user_id")
  status           String    @default("queued") // queued | running | succeeded | failed | canceled
  progress         Float     @default(0)
  timelineSnapshot Json      @map("timeline_snapshot")
  resultKey        String?   @map("result_key")
  resultBytes      Int?      @map("result_bytes")
  errorMessage     String?   @map("error_message")
  bullJobId        String?   @map("bull_job_id")
  startedAt        DateTime? @map("started_at")
  finishedAt       DateTime? @map("finished_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId, status])
  @@map("render_jobs")
}

model MediaAsset {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  kind         String   // video | audio | image
  source       String   // upload | youtube
  sourceUrl    String?  @map("source_url")
  originalName String?  @map("original_name")
  storageKey   String   @map("storage_key")
  storageBytes Int?     @map("storage_bytes")
  durationMs   Int?     @map("duration_ms")
  width        Int?
  height       Int?
  mimeType     String?  @map("mime_type")
  thumbnailKey String?  @map("thumbnail_key")
  status       String   @default("uploading") // uploading | ready | failed
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  analysisStatus String  @default("none") @map("analysis_status") // none | queued | running | done | failed
  analysisError  String? @map("analysis_error")

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects   ProjectAsset[]
  shots      Shot[]
  transcript TranscriptSegment[]
  faces      FaceDetection[]

  @@index([userId])
  @@map("media_assets")
}

model Shot {
  id           String  @id @default(uuid())
  assetId      String  @map("asset_id")
  startMs      Int     @map("start_ms")
  endMs        Int     @map("end_ms")
  index        Int
  thumbnailKey String? @map("thumbnail_key")

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("shots")
}

model TranscriptSegment {
  id      String  @id @default(uuid())
  assetId String  @map("asset_id")
  startMs Int     @map("start_ms")
  endMs   Int     @map("end_ms")
  text    String  @db.Text
  index   Int

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("transcript_segments")
}

model FaceDetection {
  id        String @id @default(uuid())
  assetId   String @map("asset_id")
  startMs   Int    @map("start_ms")
  endMs     Int    @map("end_ms")
  faceCount Int    @default(1) @map("face_count")
  bboxX     Float  @map("bbox_x")
  bboxY     Float  @map("bbox_y")
  bboxW     Float  @map("bbox_w")
  bboxH     Float  @map("bbox_h")

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("face_detections")
}

model ProjectAsset {
  projectId String   @map("project_id")
  assetId   String   @map("asset_id")
  addedAt   DateTime @default(now()) @map("added_at")

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([projectId, assetId])
  @@index([assetId])
  @@map("project_assets")
}

model IngestJob {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  kind         String    // youtube
  sourceUrl    String    @map("source_url")
  title        String?
  status       String    @default("queued") // queued | running | done | failed
  progress     Int       @default(0)
  assetId      String?   @map("asset_id")
  errorMessage String?   @map("error_message")
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("ingest_jobs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Voice {
  id             String   @id @default(uuid())
  minimaxVoiceId String   @map("minimax_voice_id")
  name           String
  sourceUrl      String?  @map("source_url")
  status         String   @default("active")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceovers Voiceover[]

  @@unique([userId, minimaxVoiceId])
  @@index([userId])
  @@map("voices")
}

model Script {
  id        String   @id @default(uuid())
  title     String
  content   String   @default("") @db.Text
  country   String?
  wordCount Int      @default(0) @map("word_count")
  rating    Int      @default(0)
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceovers Voiceover[]

  @@index([userId])
  @@map("scripts")
}

model Voiceover {
  id                String    @id @default(uuid())
  scriptId          String    @map("script_id")
  voiceId           String    @map("voice_id")
  minimaxTaskId     String?   @map("minimax_task_id")
  minimaxFileId     String?   @map("minimax_file_id")
  audioUrl          String?   @map("audio_url")
  audioExpiresAt    DateTime? @map("audio_expires_at")
  storageKey        String?   @map("storage_key")
  storageBytes      Int?      @map("storage_bytes")
  storageUploadedAt DateTime? @map("storage_uploaded_at")
  subtitlesKey      String?   @map("subtitles_key")
  status            String    @default("pending")
  characterCount    Int       @map("character_count")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  voice  Voice  @relation(fields: [voiceId], references: [id], onDelete: Cascade)

  @@index([scriptId])
  @@map("voiceovers")
}
