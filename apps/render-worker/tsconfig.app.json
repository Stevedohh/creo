{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node"],
    "rootDir": "../../",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "paths": {
      "@creo/prisma": ["../../libs/prisma/src/index.ts"],
      "@creo/storage-api": ["../../libs/storage/api/src/index.ts"],
      "@creo/auth-api": ["../../libs/auth/api/src/index.ts"],
      "@creo/video-render-api": ["../../libs/video-render/api/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../libs/prisma/src/**/*.ts",
    "../../libs/storage/api/src/**/*.ts",
    "../../libs/auth/api/src/**/*.ts",
    "../../libs/video-render/api/src/**/*.ts"
  ],
  "exclude": [
    "../../libs/prisma/dist/**/*",
    "../../libs/storage/api/dist/**/*",
    "../../libs/auth/api/dist/**/*",
    "../../libs/video-render/api/dist/**/*"
  ],
  "references": [
    { "path": "../../libs/prisma/tsconfig.lib.json" },
    { "path": "../../libs/storage/api/tsconfig.lib.json" },
    { "path": "../../libs/auth/api/tsconfig.lib.json" },
    { "path": "../../libs/video-render/api/tsconfig.lib.json" }
  ]
}
